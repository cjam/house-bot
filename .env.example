# Telegram bot token from @BotFather
TELEGRAM_TOKEN=

# Anthropic API key (the Agent SDK reads this itself; also asserted present at startup)
ANTHROPIC_API_KEY=

# Comma-separated list of Telegram chat IDs allowed to talk to the bot
ALLOWED_CHAT_IDS=

# MCP servers as a single JSON object: { "<name>": <McpServerConfig>, ... }.
# Add as many servers as you like — no code or per-server env vars needed.
# Must be a single line. http and sse transports are supported; put the full
# Authorization header (including the token) directly in the JSON.
# Example (Mealie over HTTP; add more keys for Homebox, etc.):
MCP_SERVERS={"mealie":{"type":"http","url":"http://mealie.local:9000/api/mcp","headers":{"Authorization":"Bearer YOUR_MEALIE_TOKEN"}}}

# Optional overrides
MODEL=claude-opus-4-8
SESSION_FILE=./data/sessions.json
